return {
	"AckslD/nvim-neoclip.lua",
	dependencies = {
		{ "nvim-telescope/telescope.nvim" },
	},
	config = function()
		require("neoclip").setup({
			enable_persistent_history = false,
		})
		vim.keymap.set("n", "<leader>y", "<cmd>Telescope neoclip<cr>", { desc = "Open neoclip in Telescope" })
	end,
}
